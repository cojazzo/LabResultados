    {
      "parameters": {
        "command": "=mkdir -p /data/cola_envio/resultados/procesados && mv \"/data/cola_envio/resultados/{{ $json.id }}.{{ $json.estado === 'enviado' ? 'ok' : 'err' }}.json\" /data/cola_envio/resultados/procesados/"
      },
      "id": "3e7a82d8-6f70-4ccd-a958-1f62ab808c57",
      "name": "Archivar confirmaci\u00f3n",
      "type": "n8n-nodes-base.executeCommand",
