# --- CONFIGURACIÓN DE DESPLIEGUE EN DOCKER ---

# Token seguro de tu Cloudflare Tunnel (creado desde el panel de Cloudflare Zero Trust)
CLOUDFLARE_TUNNEL_TOKEN=tu_token_de_cloudflare_aqui

# URL pública donde los pacientes accederán a tu cuestionario
# Por ejemplo: https://cuestionarios.labsanrafael.com
N8N_PUBLIC_URL=http://localhost:5678

# --- CONFIGURACIÓN DEL MCP DE N8N (Antigravity) ---
# Estas variables son de referencia. El MCP se configura manualmente en:
# C:\Users\<usuario>\.gemini\config\mcp_config.json
# No uses estos valores directamente en código.
# Ver: docs/n8n/mcp-setup.md
N8N_MCP_URL=
N8N_MCP_TOKEN=
