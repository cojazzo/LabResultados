# Seguridad Google Forms Webhooks
GOOGLE_FORMS_WEBHOOK_SECRET="tu_secreto_aqui_para_hmac"

# Email (SMTP)
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
