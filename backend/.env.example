# Database
DATABASE_URL=sqlite+aiosqlite:///./lab_resultados.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/lab_resultados

# JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Lab Info
LAB_NAME=Laboratorio Clínico San Rafael
LAB_ADDRESS=Av. Principal #123, Col. Centro, Ciudad de México
LAB_PHONE=+52 55 1234 5678
LAB_EMAIL=contacto@labsanrafael.com

# Integración n8n
N8N_API_URL="http://localhost:5678/api/v1/"
N8N_API_KEY=""
N8N_WEBHOOK_LAB04_URL="http://localhost:5678/webhook/lab-04-autorizado"
