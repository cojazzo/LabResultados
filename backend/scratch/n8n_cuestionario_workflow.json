      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8000/api/pacientes/cuestionario",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"curp\": $json.curp,\n  \"nombre\": $json.nombre,\n  \"apellido_paterno\": $json.apellido_paterno,\n  \"apellido_materno\": $json.apellido_materno || null,\n  \"sexo\": $json.sexo || null,\n  \"telefono\": $json.telefono || null,\n  \"email\": $json.email || null,\n  \"fecha_nacimiento\": $json.fecha_nacimiento ? $json.fecha_nacimiento.split('T')[0] : null,\n  \"edad\": ($json.edad && !isNaN($json.edad)) ? parseInt($json.edad) : null,\n  \"estado_origen\": $json.estado_origen || null,\n  \"domicilio\": $json.domicilio || null,\n  \"codigo_postal\": $json.codigo_postal || null,\n  \"estado_residencia\": $json.estado_residencia || null,\n  \"municipio_residencia\": $json.municipio_residencia || null,\n  \"peso\": ($json.peso && !isNaN($json.peso)) ? parseFloat($json.peso) : null,\n  \"estatura\": ($json.estatura && !isNaN($json.estatura)) ? parseFloat($json.estatura) : null,\n  \"derechohabiencia\": $json.derechohabiencia || null,\n  \"toma_suplemento\": $json.toma_suplemento || null,\n  \"tipo_agua\": $json.tipo_agua || null,\n  \"cocina_agua_llave\": $json.cocina_agua_llave || null,\n  \"padecimientos\": Array.isArray($json.padecimientos) ? $json.padecimientos : ($json.padecimientos ? [$json.padecimientos] : [])\n} }}"
      },
